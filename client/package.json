{
  "name": "napkiq-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Napkiq Restaurant - Main App + CMS Monorepo",
  "workspaces": [
    "main",
    "cms"
  ],
  "scripts": {
    "dev": "concurrently --names \"main,cms\" --prefix-colors \"cyan,magenta\" \"npm run dev:main\" \"npm run dev:cms\"",
    "dev:main": "cd main && npm run dev",
    "dev:cms": "cd cms && npm run dev",
    "build": "npm run build:main && npm run build:cms",
    "build:main": "cd main && npm run build",
    "build:cms": "cd cms && npm run build",
    "start": "concurrently --names \"main,cms\" --prefix-colors \"cyan,magenta\" \"npm run start:main\" \"npm run start:cms\"",
    "start:main": "cd main && npm run start",
    "start:cms": "cd cms && npm run start",
    "install:all": "cd main && npm install && cd ../cms && npm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
