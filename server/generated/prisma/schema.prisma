generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  Male
  Female
  Transgender
  RatherNotSay
}

enum MaritalStatus {
  Married
  Unmarried
}

enum ReviewType {
  first_visit
  repeat
}

enum VisitType {
  qr_scan
  payment
}

enum AutomationType {
  birthday_whatsapp
  birthday_email
  anniversary_whatsapp
  anniversary_email
  reengagement_whatsapp
  reengagement_email
}

enum MessageStage {
  five_days_before
  one_day_before
  thirty_days_inactive
  on_day
}

enum AutomationStatus {
  success
  failed
}

enum StaffRole {
  admin // UniCord — full CMS access including automation
  owner // Nitesh Save — all outlets, no automation
  franchise_owner // Per-outlet staff — single outlet only
  main_owner // @deprecated — kept for migration safety, will be removed
}

model Outlet {
  id            String   @id @default(uuid()) @db.Uuid
  code          String   @unique @db.VarChar(10)
  slug          String   @unique @db.VarChar(50)
  name          String
  location      String?
  address       String?
  googlePlaceId String   @unique
  googleMapsUrl String?
  instagramUrl  String?
  facebookUrl   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customers      Customer[]      @relation("FirstVisitOutlet")
  reviews        Review[]
  visits         CustomerVisit[]
  menuCategories MenuCategory[]
  staff          Staff[]

  @@map("outlets")
}

model Customer {
  id                      String        @id @default(uuid()) @db.Uuid
  deviceId                String        @unique
  fullName                String
  phone                   String        @unique @db.VarChar(15)
  email                   String?
  birthDate               DateTime      @db.Date
  anniversaryDate         DateTime?     @db.Date
  gender                  Gender
  maritalStatus           MaritalStatus
  firstVisitOutletId      String?       @db.Uuid
  firstVisitOutlet        Outlet?       @relation("FirstVisitOutlet", fields: [firstVisitOutletId], references: [id])
  lastVisitDate           DateTime?
  totalVisits             Int           @default(1)
  hasSubmittedFirstReview Boolean       @default(false)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  reviews        Review[]
  visits         CustomerVisit[]
  automationLogs AutomationLog[]

  @@index([deviceId])
  @@index([phone])
  @@index([lastVisitDate])
  @@index([birthDate])
  @@index([anniversaryDate])
  @@map("customers")
}

model Review {
  id             String     @id @default(uuid()) @db.Uuid
  customerId     String?    @db.Uuid
  customer       Customer?  @relation(fields: [customerId], references: [id])
  outletId       String     @db.Uuid
  outlet         Outlet     @relation(fields: [outletId], references: [id])
  reviewText     String?
  stars          Int
  reviewType     ReviewType
  postedToGoogle Boolean    @default(false)
  isVisible      Boolean    @default(true)
  createdAt      DateTime   @default(now())

  @@index([outletId, createdAt])
  @@index([customerId])
  @@map("reviews")
}

model CustomerVisit {
  id         String    @id @default(uuid()) @db.Uuid
  customerId String?   @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id])
  deviceId   String
  outletId   String    @db.Uuid
  outlet     Outlet    @relation(fields: [outletId], references: [id])
  visitType  VisitType @default(qr_scan)
  visitedAt  DateTime  @default(now())

  @@index([customerId, visitedAt])
  @@index([deviceId, visitedAt])
  @@index([outletId, visitedAt])
  @@map("customer_visits")
}

model MenuCategory {
  id           String     @id @default(uuid()) @db.Uuid
  name         String
  displayOrder Int?
  isActive     Boolean    @default(true)
  outletId     String?    @db.Uuid
  outlet       Outlet?    @relation(fields: [outletId], references: [id])
  createdAt    DateTime   @default(now())
  items        MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id            String       @id @default(uuid()) @db.Uuid
  categoryId    String       @db.Uuid
  category      MenuCategory @relation(fields: [categoryId], references: [id])
  name          String
  description   String?
  price         Decimal?     @db.Decimal(10, 2)
  priceVariants Json?
  isVeg         Boolean      @default(true)
  imageUrl      String?      @db.VarChar(500)
  isAvailable   Boolean      @default(true)
  displayOrder  Int?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([categoryId, displayOrder])
  @@map("menu_items")
}

model AutomationLog {
  id             String           @id @default(uuid()) @db.Uuid
  customerId     String?          @db.Uuid
  customer       Customer?        @relation(fields: [customerId], references: [id])
  automationType AutomationType
  messageStage   MessageStage
  status         AutomationStatus
  errorMessage   String?
  sentAt         DateTime         @default(now())

  @@index([customerId, sentAt])
  @@index([automationType, status])
  @@map("automation_logs")
}

// staff.id mirrors auth.users.id in Supabase Auth
model Staff {
  id               String    @id @db.Uuid
  username         String?   @unique // Used for CMS login (populated via setup script)
  fullName         String
  email            String    @unique
  phone            String?   @db.VarChar(15)
  role             StaffRole
  isAdmin          Boolean   @default(false)
  assignedOutletId String?   @db.Uuid
  assignedOutlet   Outlet?   @relation(fields: [assignedOutletId], references: [id])
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("staff")
}
