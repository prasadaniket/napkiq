# Worker env vars are set via Cloudflare dashboard or wrangler CLI.
# Do NOT commit real secrets here.

# Set this via: wrangler secret put AUTOMATION_SECRET
# Must match AUTOMATION_SECRET in the server .env
AUTOMATION_SECRET=<same-value-as-server-AUTOMATION_SECRET>

# Configured in wrangler.toml [vars] — not a secret
SERVER_URL=https://so-blik.onrender.com
